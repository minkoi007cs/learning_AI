# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_study_os?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-in-production"
JWT_EXPIRATION="7d"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1"
OPENAI_FALLBACK_MODEL="gpt-4.1-mini"

# S3 / Cloudflare R2
S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="ai-study-os"
S3_REGION="auto"

# App
PORT=3001
NODE_ENV=development
API_PREFIX=v1
CORS_ORIGINS="http://localhost:3000"

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
